{
  "name": "@ubloimmo/front-tokens",
  "description": "Figma team styles converted to code-ready css tokens",
  "version": "0.2.0",
  "private": false,
  "module": "lib/index.ts",
  "main": "lib/index.ts",
  "author": "Jean-Nicolas Veigel <art.jnveigel@gmail.com>",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/types/icons.d.ts",
      "import": "./dist/icons.js",
      "default": "./dist/icons.js"
    },
    "./tokens.collection": {
      "types": "./dist/types/tokens.collection.d.ts",
      "import": "./dist/tokens.collection.js",
      "default": "./dist/tokens.collection.js"
    },
    "./tokens.all": {
      "types": "./dist/types/tokens.all.d.ts",
      "import": "./dist/tokens.all.js",
      "default": "./dist/tokens.all.js"
    },
    "./tokens.values": {
      "types": "./dist/types/tokens.values.d.ts",
      "import": "./dist/tokens.values.js",
      "default": "./dist/tokens.values.js"
    }
  },
  "homepage": "https://github.com/UbloImmo/front-tokens",
  "repository": {
    "type": "git",
    "url": "https://github.com/UbloImmo/front-tokens"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.58.12",
    "@types/bun": "^1.3.14",
    "@typescript-eslint/eslint-plugin": "^5.58.0",
    "@typescript-eslint/parser": "^5.58.0",
    "ajv": "^8.20.0",
    "bun-types": "latest",
    "eslint": "^8.38.0",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-local-rules": "^1.1.0",
    "eslint-plugin-prettier": "^4.0.0",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^4.2.0",
    "eslint-plugin-storybook": "^0.6.15",
    "prettier": "^2.8.7",
    "ts-dedent": "^2.3.0",
    "unplugin-dts": "^1.0.3",
    "vite": "^8.1.5"
  },
  "peerDependencies": {
    "@ubloimmo/front-util": "^0.1.1",
    "typescript": "^5.0.0"
  },
  "scripts": {
    "generate": "bun src/scripts/generate.ts",
    "update": "bun src/scripts/update.ts",
    "test:types": "tsc --noEmit",
    "test:types:watch": "tsc --noEmit --watch",
    "test:lint": "eslint . --cache --cache-location .cache/eslint",
    "test:unit": "bun test"
  },
  "type": "module",
  "dependencies": {
    "@ubloimmo/front-util": "^0.1.1"
  }
}
